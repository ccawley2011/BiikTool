CC = cc
LD = link

CFLAGS = -IC: -throwback
LDFLAGS = -aif

OBJS = @.o.main @.o.utils @.o.archive @.o.extract @.o.compress @.o.musx @.o.adpcm @.o.g711 C:o.stubs
EXECUTABLE = @.biik-tool

all: $(EXECUTABLE)

$(EXECUTABLE):  $(OBJS)
        $(LD) $(LDFLAGS) -o $@ $(OBJS)

.c.o:
	@CDir @.o
        $(CC) $(CFLAGS) -c -o $@ $<

clean:
	Remove $(EXECUTABLE)
	X Wipe @.o ~CFR~V
